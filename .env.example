# =============================================================================
# ReleaseGuard Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# --- Google Cloud ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1

# --- Gemini API ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- GitHub ---
GITHUB_TOKEN=your-github-token
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=releaseguard-agent
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# --- Demo Store ---
DEMO_STORE_URL=http://localhost:8081
DEMO_STORE_PORT=8081

# --- ReleaseGuard Service ---
# App internal port. Docker Compose exposes this as localhost:8085.
RELEASEGUARD_PORT=8080
RELEASEGUARD_SHARED_TOKEN=your-shared-security-bearer-token

# --- Preview Environment ---
# Cloud Run preview URL pattern (set automatically during deploy)
PREVIEW_URL_TEMPLATE=https://demo-store-pr-{pr_number}-xxxxxxxxxx.a.run.app

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
